{
	"name": "calisto-studio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "NODE_OPTIONS='--inspect=localhost:9222' vite dev --host ",
		"dev:remote": "wrangler dev --remote",
		"build": "vite build",
		"preview": "pnpm run build && wrangler dev",
		"preview:staging": "pnpm run build && wrangler deploy --env=staging",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"new": "sh scripts/github_init.sh",
		"deploy": "git pull upstream main --no-edit --no-rebase -X ours && pnpm install && pnpm typegen:payload && sh scripts/add_domain_wrangler.sh && PUBLIC_ENV=PROD vite build && wrangler deploy --env=production && pnpm pushVersion && exit 0",
		"deploy:staging": "PUBLIC_DEV_CMS=https://staging-cms.calisto.studio vite build && wrangler deploy --env=staging",
		"pushVersion": "git push origin main",
		"pushVersion:old": "git add . && git commit -m \"$(git rev-list --count main)\" && git push origin main",
		"typegen:payload": "cp ../cms-mt/src/payload-types.ts ./src/payload-types.ts",
		"typegen:cf": "wrangler types && mv worker-configuration.d.ts src/",
		"update-kv": "wrangler kv bulk put blobs/data.json --local --binding CALISTO_STUDIO_KV_CACHE --preview",
		"embolden": "wasm-pack build packages/epub_converter --target=web --out-dir ../../src/lib/wasm/embolden && rm src/lib/wasm/embolden/.gitignore"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250430.0",
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.17.0",
		"@sveltejs/adapter-auto": "^6.1.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.53.0",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.0",
		"@types/lodash-es": "^4.17.12",
		"bits-ui": "^2.18.1",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.45.4",
		"svelte-check": "^4.0.0",
		"svelte-sonner": "^1.0.5",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.3.5",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.2.6",
		"wrangler": "^4.14.1"
	},
	"dependencies": {
		"@motionone/types": "^10.17.1",
		"@payloadcms/live-preview": "^3.72.0",
		"@payloadcms/richtext-lexical": "^3.72.0",
		"@tanstack/svelte-form": "^1.9.0",
		"@types/lodash": "^4.17.20",
		"clsx": "^2.1.1",
		"embla-carousel-fade": "^8.6.0",
		"embla-carousel-svelte": "^8.6.0",
		"fflate": "^0.8.2",
		"iconify-icon": "^3.0.2",
		"lexical": "^0.31.0",
		"lucide": "^0.503.0",
		"motion": "^12.38.0"
	}
}
